# Copy to docker/bot/.env before: docker compose -f docker-compose.stack.yml up -d
# Steam credentials and bot settings — never commit the real file.

NODE_ENV=production

STEAM_ACCOUNT_NAME=
STEAM_PASSWORD=
STEAM_SHARED_SECRET=
STEAM_IDENTITY_SECRET=
STEAM_API_KEY=

BPTF_ACCESS_TOKEN=
BPTF_API_KEY=

ADMINS=[{ "steam": "<your steamid 64>", "discord": null }]
KEEP=[]
GROUPS=["103582791475394761"]
ALERTS=["trade", "version"]

ENABLE_SOCKET=true
IPC=true
TLS=false

DEBUG=true
DEBUG_FILE=true
ENABLE_SAVE_LOG_FILE=true
