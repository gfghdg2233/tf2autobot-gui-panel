# TF2Autobot GUI — copy to .env and adjust
# This file is safe to commit. Never commit your real .env.

NODE_ENV=production

# Steam Web API key (required if STEAM_AUTH=true)
# https://steamcommunity.com/dev/apikey
API_KEY=

# Require Steam login to access the panel (true/false)
STEAM_AUTH=true

# HTTP port for the web panel
PORT=3000

# Outbound HTTP proxy (optional — leave unset on most home/NAS installs)
# Broken HTTP_PROXY/HTTPS_PROXY system env vars can prevent schema/prices from loading.
# Only set HTTP_PROXY_ENABLED=true if you intentionally use a proxy for outbound requests.
# HTTP_PROXY_ENABLED=false

# HTTPS settings (optional)
PORT_HTTPS=443
SSL=false
CERT_FILE=local.crt
CERT_KEY=local.key

# Set VPS=true when hosting on a public server
VPS=false
ADDRESS=localhost

# Session secret — change this to a long random string
SESSION_SECRET=change-me-to-a-random-string

# Panel self-update (optional)
# GitHub repo for release checks (owner/name)
PANEL_GITHUB_REPO=uwu6967/tf2autobot-gui-panel
# Git branch to pull on update
PANEL_GIT_BRANCH=main
# PM2 process name to restart after update (if using PM2)
PANEL_PM2_NAME=GUI
# Auto-check for updates on startup and on interval (true/false)
PANEL_AUTO_CHECK=false
# Auto-install when a newer release is found (true/false)
PANEL_AUTO_UPDATE=false
# Hours between automatic update checks (when PANEL_AUTO_CHECK=true)
PANEL_CHECK_INTERVAL_HOURS=6

# Discord webhook for panel release announcements (optional)
# Trade webhooks are configured in Settings → discordWebhook (bot options)
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_ENABLED=true
DISCORD_WEBHOOK_ALWAYS=false
# DISCORD_WEBHOOK_NAME=TF2Autobot GUI
# DISCORD_WEBHOOK_AVATAR=
# DISCORD_EMBED_COLOR=9171753
