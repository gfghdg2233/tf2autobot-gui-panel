<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}TF2Autobot — Mann Co. Control Panel{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <script>
        (function () {
            try {
                var key = 'tf2gui-theme';
                var theme = localStorage.getItem(key) || 'mann-co';
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) {}
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Roboto+Condensed:wght@400;500;700&display=swap" rel="stylesheet">
    {{ load_entry_tags('base', 'css') | safe }}
    {{ load_entry_tags('base', 'js') | safe}}
    {% block stylesheets %}{% endblock %}
</head>
<body class="tf2-body">
<div class="tf2-shell">
    <header class="tf2-header">
        <div class="tf2-header-inner">
            <a class="tf2-brand" href="/">
                <span class="tf2-brand-badge">TF2</span>
                <span class="tf2-brand-text">
                    <strong>AUTOBOT</strong>
                    <small>Mann Co. Trading Terminal</small>
                </span>
            </a>
            <div class="tf2-header-controls">
                <div class="tf2-theme-picker">
                    <label for="tf2-theme-select">Theme</label>
                    <select id="tf2-theme-select" class="tf2-theme-select" aria-label="Color theme">
                        <option value="mann-co">Mann Co. (Default)</option>
                        <option value="blu-base">BLU Base</option>
                        <option value="red-fortress">RED Fortress</option>
                        <option value="australium">Australium Gold</option>
                        <option value="neon-grid">Neon Grid</option>
                        <option value="forest-camo">Forest Camo</option>
                        <option value="royal-purple">Royal Purple</option>
                        <option value="ocean-depth">Ocean Depth</option>
                        <option value="crimson-night">Crimson Night</option>
                        <option value="arctic-steel">Arctic Steel</option>
                        <option value="sunset-harvest">Sunset Harvest</option>
                    </select>
                </div>
                <div class="tf2-header-tag">v{{ guiVersion }}</div>
            </div>
        </div>
    </header>

    <nav class="tf2-nav" aria-label="Main navigation">
        <div class="tf2-nav-inner">
            <a href="/" class="tf2-nav-link" data-nav>
                <span class="tf2-nav-icon">&#9876;</span>
                Pricelist
            </a>
            <a href="/trades" class="tf2-nav-link" data-nav>
                <span class="tf2-nav-icon">&#8644;</span>
                Trades
            </a>
            <a href="/profit" class="tf2-nav-link" data-nav>
                <span class="tf2-nav-icon">&#9733;</span>
                Profit
            </a>
            <a href="/config" class="tf2-nav-link" data-nav>
                <span class="tf2-nav-icon">&#9881;</span>
                Settings
            </a>
            <a href="/updates" class="tf2-nav-link" data-nav>
                <span class="tf2-nav-icon">&#128196;</span>
                Update Logs
            </a>
        </div>
    </nav>

    <main class="app-root tf2-main" id="app">
        {% block body %}{% endblock %}
    </main>

    <footer class="tf2-footer">
        <span>TF2Autobot GUI</span>
        <span class="tf2-footer-dot">&bull;</span>
        <span>Mann Co. approved*</span>
    </footer>
</div>
{% block javascripts %}{% endblock %}
</body>
</html>
