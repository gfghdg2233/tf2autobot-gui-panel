<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}TF2Autobot Panel{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <script>
        (function () {
            try {
                var key = 'tf2gui-theme';
                var theme = localStorage.getItem(key) || 'sourcebans';
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) {}
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    {{ load_entry_tags('base', 'css') | safe }}
    {{ load_entry_tags('base', 'js') | safe}}
    {% block stylesheets %}{% endblock %}
</head>
<body class="sb-body">
<div class="tf2-shell sb-shell" id="tf2-shell">
    <button type="button" class="tf2-sidebar-toggle" id="tf2-sidebar-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <aside class="tf2-sidebar sb-sidebar" id="tf2-sidebar" aria-label="Main navigation">
        <a class="tf2-sidebar-brand sb-sidebar-brand" href="/">
            <span class="sb-brand-mark" aria-hidden="true">TF2</span>
            <span class="tf2-sidebar-brand-text">
                <strong>Autobot Panel</strong>
                <small>Console</small>
            </span>
        </a>

        <nav class="tf2-sidebar-nav sb-sidebar-nav">
            <a href="/" class="tf2-sidebar-link sb-sidebar-link" data-nav>
                <span class="tf2-sidebar-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                </span>
                <span class="tf2-sidebar-label">Pricelist</span>
            </a>
            <a href="/trades" class="tf2-sidebar-link sb-sidebar-link" data-nav>
                <span class="tf2-sidebar-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                </span>
                <span class="tf2-sidebar-label">Trades</span>
            </a>
            <a href="/unlisted" class="tf2-sidebar-link sb-sidebar-link" data-nav>
                <span class="tf2-sidebar-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                </span>
                <span class="tf2-sidebar-label">Unlisted</span>
            </a>
            <a href="/profit" class="tf2-sidebar-link sb-sidebar-link" data-nav>
                <span class="tf2-sidebar-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                </span>
                <span class="tf2-sidebar-label">Profit</span>
            </a>
            <a href="/updates" class="tf2-sidebar-link sb-sidebar-link" data-nav>
                <span class="tf2-sidebar-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </span>
                <span class="tf2-sidebar-label">Updates</span>
            </a>
            <a href="/config" class="tf2-sidebar-link sb-sidebar-link" data-nav>
                <span class="tf2-sidebar-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                </span>
                <span class="tf2-sidebar-label">Settings</span>
            </a>
        </nav>

        <div class="tf2-sidebar-bottom sb-sidebar-bottom">
            <div class="tf2-sidebar-theme sb-sidebar-theme">
                <label for="tf2-theme-select">Theme</label>
                <select id="tf2-theme-select" class="sb-theme-select tf2-theme-select" aria-label="Color theme">
                    <option value="sourcebans">Console (Default)</option>
                    <option value="mann-co">Mann Co.</option>
                    <option value="blu-base">BLU Base</option>
                    <option value="red-fortress">RED Fortress</option>
                    <option value="australium">Australium</option>
                    <option value="neon-grid">Neon Grid</option>
                    <option value="forest-camo">Forest Camo</option>
                    <option value="royal-purple">Royal Purple</option>
                    <option value="ocean-depth">Ocean Depth</option>
                    <option value="crimson-night">Crimson Night</option>
                    <option value="arctic-steel">Arctic Steel</option>
                    <option value="sunset-harvest">Sunset Harvest</option>
                </select>
            </div>

            <div class="sb-version-row">
                <a href="/updates" class="sb-version-chip" id="tf2-sidebar-version" title="Panel version">Panel v{{ guiVersion }}</a>
                <a href="/updates" class="sb-version-chip" id="tf2-sidebar-bot-version" title="Bot version">Bot …</a>
            </div>

            <span class="sb-bot-status sb-bot-status-sidebar" id="sb-bot-status" title="Bot IPC connection">Bot: …</span>
        </div>
    </aside>

    <div class="tf2-content-wrap sb-content-wrap">
        <main class="sb-main app-root tf2-main" id="app">
            {% block body %}{% endblock %}
        </main>
    </div>
</div>
{% block javascripts %}{% endblock %}
</body>
</html>
